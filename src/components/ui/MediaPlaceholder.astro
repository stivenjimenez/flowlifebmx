---
interface Props {
  label: string;
  src?: string;
  alt?: string;
  esVideo?: boolean;
  poster?: string;
  ratio?: string; // aspect-ratio CSS, ej. "4/3"
  small?: boolean; // label de 11px (fotos secundarias)
  class?: string;
}

const { label, src, alt = '', esVideo = false, poster, ratio, small = false, class: className } = Astro.props;
const estiloCaja = ratio ? `aspect-ratio:${ratio}` : undefined;
const estiloMedia = [ratio ? `aspect-ratio:${ratio}` : null, 'width:100%', 'object-fit:cover'].filter(Boolean).join(';');
---

{
  src && esVideo ? (
    <video class={className} src={src} poster={poster} style={estiloMedia} controls playsinline />
  ) : src ? (
    <img class={className} src={src} alt={alt} style={estiloMedia} />
  ) : (
    <div class:list={['fl-placeholder', { 'fl-placeholder--sm': small }, className]} style={estiloCaja}>
      <span class="fl-placeholder-label">{label}</span>
    </div>
  )
}
