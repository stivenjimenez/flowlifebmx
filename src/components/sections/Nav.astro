---
import { navLinks } from '../../data/site';
---

<header class="header">
  <div class="inner">
    <a href="#inicio" class="logo">
      <span class="logoNombre">FLOW <span class="logoAcc">LIFE</span></span>
      <span class="logoSub">BMX FREESTYLE</span>
    </a>
    <nav class="nav">
      <div class="links">
        {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>
      <a href="#contacto" class="cta">Reservar clase</a>
      <button id="menu-toggle" class="hamburguesa" type="button" aria-expanded="false" aria-controls="menu-movil" aria-label="Abrir menú">☰</button>
    </nav>
  </div>
</header>

<div id="menu-movil" class="menuMovil">
  {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
  <a href="#contacto" class="reservar">Reservar clase</a>
</div>

<script>
  const boton = document.getElementById('menu-toggle') as HTMLButtonElement;
  const menu = document.getElementById('menu-movil') as HTMLElement;

  const setAbierto = (abierto: boolean) => {
    menu.classList.toggle('abierto', abierto);
    boton.textContent = abierto ? '✕' : '☰';
    boton.setAttribute('aria-expanded', String(abierto));
  };

  boton.addEventListener('click', () => setAbierto(!menu.classList.contains('abierto')));
  menu.querySelectorAll('a').forEach((enlace) => enlace.addEventListener('click', () => setAbierto(false)));
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 11, 11, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 8px;
    text-decoration: none;
    white-space: nowrap;
  }
  .logoNombre {
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 1px;
    color: var(--text);
  }
  .logoAcc {
    color: var(--acc);
  }
  .logoSub {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
  }
  .links a:hover {
    color: var(--text);
  }
  .cta {
    background: var(--acc);
    color: var(--accInk);
    text-decoration: none;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 18px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .cta:hover {
    filter: brightness(1.1);
  }
  .hamburguesa {
    display: none;
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 14px;
    padding: 8px 12px;
    cursor: pointer;
    border-radius: 3px;
  }
  .menuMovil {
    display: none;
    position: fixed;
    inset: 64px 0 0 0;
    z-index: 49;
    background: rgba(11, 11, 11, 0.97);
    backdrop-filter: blur(10px);
    flex-direction: column;
    gap: 4px;
    padding: 24px;
  }
  .menuMovil a {
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 34px;
    padding: 10px 8px;
    border-bottom: 1px solid var(--border);
  }
  .menuMovil .reservar {
    color: var(--acc);
    border-bottom: none;
  }

  @media (max-width: 859px) {
    .links {
      display: none;
    }
    .hamburguesa {
      display: inline-block;
    }
    .menuMovil.abierto {
      display: flex;
    }
  }

  @media (max-width: 639px) {
    .logoSub {
      display: none;
    }
  }

  @media (max-width: 479px) {
    .inner {
      gap: 12px;
      padding: 0 16px;
    }
    .nav {
      gap: 12px;
    }
    .cta {
      font-size: 11px;
      padding: 10px 12px;
    }
  }
</style>
