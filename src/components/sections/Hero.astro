---
import { heroVideo } from '../../data/videos';
import MediaPlaceholder from '../ui/MediaPlaceholder.astro';
---

<section id="inicio">
  <div class="inner">
    <div class="contenido">
      <div class="fl-kicker kicker">CLASES · SPOTS · COMUNIDAD</div>
      <h1>Aprende BMX freestyle<br />con un mentor que te<br /><span class="acento">acompaña en serio.</span></h1>
      <p>Clases presenciales, progresión técnica, spots reales, comunidad y contenido para riders de todos los niveles.</p>
      <div class="ctas">
        <a href="#agenda" class="btnAcc">Ver agenda</a>
        <a href="#contacto" class="btnGhost">Reservar clase</a>
        <a href="#galeria" class="btnTexto">Ver videos →</a>
      </div>
    </div>
    <div class="media">
      <MediaPlaceholder label={heroVideo.label} src={heroVideo.src} poster={heroVideo.poster} esVideo />
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 72px) clamp(16px, 4vw, 24px) 0;
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 48px;
    align-items: end;
  }
  .contenido {
    padding-bottom: clamp(40px, 6vw, 72px);
  }
  .contenido .kicker {
    margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 7.5vw, 104px);
    line-height: 0.92;
    margin: 0 0 24px;
    letter-spacing: 0.5px;
  }
  .acento {
    color: var(--acc);
  }
  p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
    margin: 0 0 32px;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .btnAcc {
    background: var(--acc);
    color: var(--accInk);
    text-decoration: none;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 15px 26px;
    border-radius: 3px;
  }
  .btnAcc:hover {
    filter: brightness(1.1);
  }
  .btnGhost {
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 26px;
    border-radius: 3px;
  }
  .btnGhost:hover {
    background: var(--surface);
  }
  .btnTexto {
    background: transparent;
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 15px 12px;
  }
  .btnTexto:hover {
    color: var(--text);
  }
  .media {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .media :global(.fl-placeholder) {
    height: 420px;
    border-bottom: none;
    padding: 24px;
  }

  @media (max-width: 859px) {
    .inner {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
